modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
integrations = ["firebase_barebones_flask:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "openssl", "postgresql", "rustc", "unzip", "zip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api && python index.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]
