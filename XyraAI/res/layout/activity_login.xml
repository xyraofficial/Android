<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_gradient" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp">

            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/ivLogoGlow"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:src="@drawable/bg_logo_glow"
                    android:alpha="0" />

                <LinearLayout
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_login_logo_container"
                    android:gravity="center"
                    android:elevation="12dp">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/ic_xyra_avatar"
                        android:scaleType="centerInside"
                        android:contentDescription="XyraAI Logo" />

                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="XyraAI"
                android:textColor="@color/textPrimary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Asisten AI Cerdas untuk Anda"
                android:textColor="@color/textSecondary"
                android:textSize="16sp"
                android:letterSpacing="0.02" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk untuk memulai"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:id="@+id/btnGoogleSignIn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_google_button_login"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_google"
                    android:contentDescription="Google" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:text="Masuk dengan Google"
                    android:textColor="#1F1F1F"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="24dp"
                android:indeterminateTint="@color/colorPrimary"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Dengan masuk, Anda menyetujui\nSyarat dan Ketentuan kami"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:alpha="0.7" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
