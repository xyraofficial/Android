<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingLeft="8dp"
    android:paddingRight="48dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/aiBubbleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_ai"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/messageContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/actionButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnTTS"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Text to Speech"
                android:src="@drawable/ic_volume"
                android:padding="6dp"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/btnBookmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmark"
                android:src="@drawable/ic_bookmark"
                android:padding="6dp"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Share"
                android:src="@drawable/ic_share"
                android:padding="6dp"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Copy"
                android:src="@drawable/ic_copy"
                android:padding="6dp"
                android:alpha="0.7" />

            <ImageButton
                android:id="@+id/btnRunCode"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Run Code"
                android:src="@drawable/ic_play"
                android:padding="6dp"
                android:alpha="0.7"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:textColor="@color/textSecondary"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
