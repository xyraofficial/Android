##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, you may
#       specify it here.
#
#   (2) Gradle will search for itself in java (calling itself) and failing.
#
##############################################################################

# You can try to enable colors by uncommenting (just remove the # in front) the lines below.
# GREEN='\033[0;32m'
# RED='\033[0;31m'

if [ -z "$JAVA_HOME" ] ; then
    JAVA_EXE="`which java`"
    if [ -z "$JAVA_EXE" ] ; then
        echo "Error: JAVA_HOME is not set and no 'java' command could be found in your PATH."
        echo ""
        echo "Please set the JAVA_HOME variable in your environment to match the"
        echo "location of your Java installation."
        exit 1
    fi
else
    JAVA_EXE="$JAVA_HOME/bin/java"
fi
if [ ! -x "$JAVA_EXE" ] ; then
    echo "Error: JAVA_HOME is set to a path with no java executable inside! ($JAVA_EXE)"
    echo ""
    echo "Please set the JAVA_HOME variable in your environment to match the"
    echo "location of your Java installation."
    exit 1
fi

# traverse directories down to root till you find .classpath, .project, .gradle or an empty parent
find_gradle_home() {
  local dir
  local parent
  dir="$( cd "$1" && pwd )"
  parent="$( dirname "$dir" )"
  if [ "$parent" = "$dir" ]; then
    echo "$dir"
    cd /
    return
  fi
  if [ -e "$dir/.gradle" ] || [ -e "$dir/.classpath" ] || [ -e "$dir/.project" ]; then
    echo "$dir"
    return
  fi
  find_gradle_home "$parent"
}

export GRADLE_HOME="$( find_gradle_home "$PWD" )"
cd "$GRADLE_HOME"

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn() {
    if [ "$QUIET" != yes ] ; then
        printf '%s\n' "$*" >&2
    fi
}

die() {
    printf '%s\n' "$1" >&2
    exit "$2"
}

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to \"$JAVA_HOME\" but JAVA_EXE=\"$JAVACMD\" is not executable!"
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$msys" ; then
    case $( ulimit -S -n ) in #(
      ''|unlimited) :;;
      *)
        # In POSIX sh, ulimit -n is undefined. That's OK.
        case $( ulimit -n ) in
          ulimit: unlimited) :;;
          *) ulimit -n 65536 ;;
        esac ;;
    esac
fi

# Escape application args
save() {
    local cmd
    printf '%s\n' "$*" | sed "s/'/'\\\\''/g;1s/^/'/;\$s/\$/' \\\\/" ; return
}
APP_ARGS=$( save "$@" )
eval "set -- $APP_ARGS"

# When using eval with command line arguments, we need to handle paths
# that may contain spaces or "\$" characters.
#
# Inspired by Apache Ant.
#
init() {
    p=""
    temp=""
    div=""
    for arg in "$@"
    do
        if test -d "$arg" ; then
            p="$p$div`cd "$arg" 2>/dev/null && pwd || echo "$arg" | sed 's/ /\\ /g'`"
        else
            p="$p$div`echo "$arg" | sed 's/ /\\ /g'`"
        fi
        div=" "
    done
    eval "set -- $p"
}
init "$@"

# Start the Gradle daemon in the background.
exec "$JAVACMD" $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \
        -classpath "$CLASSPATH" \
        org.gradle.wrapper.GradleWrapperMain "$@"
